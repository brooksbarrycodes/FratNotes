# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# -----------------------------------------------------------------------------
# AI (study pass + chat)
# -----------------------------------------------------------------------------
# Recommended: set OPENAI_API_KEY (if AI_PROVIDER is unset, OpenAI is used when
# the key is present). Optional OPENAI_BASE_URL for OpenRouter, Groq, etc.
# AI_PROVIDER="openai"
OPENAI_API_KEY=""
# Prefer a stable model id for JSON study-pass (e.g. gpt-4o-mini). openrouter/auto
# can be inconsistent for strict structured output; test before production.
OPENAI_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"

# Study pass sends at most ~36k chars of extracted PDF text to the model (see
# MAX_STUDY_PASS_CHARS in src/lib/study-pass-normalize.ts); huge PDFs are truncated.

# Optional: label shown in the Study Buddy panel (defaults to "Study assistant").
# NEXT_PUBLIC_AI_CHAT_LABEL="OpenRouter · gpt-4o-mini"

# Self-hosted Ollama (default when no OPENAI_API_KEY): use AI_PROVIDER=ollama or omit key.
# Local dev: omit OLLAMA_BASE_URL to use http://127.0.0.1:11434.
# Production: set OLLAMA_BASE_URL to your HTTPS reverse proxy origin.
# Local Ollama uses HTTP on port 11434 (not https, not 14434 — common typos).
# AI_PROVIDER="ollama"
# OLLAMA_BASE_URL="https://your-ollama-server.example.com"
OLLAMA_MODEL="llama3.1:8b"
OLLAMA_API_KEY=""

# -----------------------------------------------------------------------------
# Production Ollama (operator checklist — run on your VPS or private host)
# -----------------------------------------------------------------------------
# 1. Install Ollama and pull the chat model, e.g. ollama pull llama3.1:8b
# 2. Do not expose raw port 11434 to the public internet without protection.
# 3. Put TLS in front (Caddy/nginx) and use a shared secret: your proxy checks
#    Authorization: Bearer <token>, then forwards to 127.0.0.1:11434.
# 4. Set OLLAMA_BASE_URL to that HTTPS origin below; set OLLAMA_API_KEY to the
#    same token if your proxy expects Bearer auth.
# 5. In Vercel/hosting, set the same env vars and redeploy.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# Next Auth Discord Provider
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="file:./db.sqlite"
